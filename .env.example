GROQ_API_KEY=gsk_your-groq-api-key-here
PORT=8080

# Turso database
TURSO_DB_URL=libsql://your-db-name.turso.io?authToken=your-token

# CORS: comma-separated origins, leave empty to allow all
CORS_ORIGINS=

# Stripe (optional — app runs fine without it for free tier)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# OAuth (optional — for client portal login)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Sentry (optional — error alerting)
SENTRY_DSN=https://your-dsn@sentry.io/project-id
